# Public checkout URLs can be added after Creem products are created.
NEXT_PUBLIC_CREEM_PRO_URL=

# Server-only values. CREEM_API_KEY enables Creem license activation/validation.
CREEM_API_KEY=
CREEM_TEST_MODE=false
CREEM_API_BASE_URL=
CREEM_WEBHOOK_SECRET=
RESEND_API_KEY=
LICENSE_SIGNING_SECRET=

# Optional no-database activation codes for manual/email delivery.
# Generate with:
# SLH_ACTIVATION_CODE_SECRET="replace-with-a-long-random-secret" node scripts/generate_activation_codes.mjs 100
SLH_ACTIVATION_CODE_SECRET=

# Local-only license testing. Do not enable in production.
SLH_ENABLE_TEST_LICENSE=false
LICENSE_STORAGE_DRIVER=
